{
  "C_Cpp.default.includePath": [
    "${workspaceFolder}",
    "${workspaceFolder}/include",
    "/usr/local/opt/avr-gcc/avr/include",
    "/usr/avr/include",
    "/opt/homebrew/opt/avr-gcc/avr/include"
  ],
  "C_Cpp.default.defines": [
    "__AVR_ATmega32A__",
    "F_CPU=8000000UL",
    "__GNUC__",
    "nullptr=0"
  ],
  "C_Cpp.default.cppStandard": "c++11",
  "C_Cpp.default.compilerPath": "/usr/local/bin/avr-g++",
  "C_Cpp.intelliSenseEngine": "Tag Parser",
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[c]": {
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "files.exclude": {
    "**/*.o": true,
    "**/*.elf": true,
    "**/*.bin": true,
    "**/*.hex": false
  },
  "search.exclude": {
    "**/*.o": true,
    "**/*.elf": true,
    "**/*.bin": true
  }
}
